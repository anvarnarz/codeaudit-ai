# API Key Encryption Master Key (auto-generated on first run)
# If you need to set it manually:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Stored at: ~/.codeaudit-ai/.env
ENCRYPTION_KEY=

# Port (default: 3000)
PORT=3000
